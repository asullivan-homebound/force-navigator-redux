{
  "name": "force-navigator-redux",
  "version": "5.0.4",
  "description": "Salesforce Navigator Redux",
  "private": true,
  "scripts": {
    "watch": "webpack --mode=development --watch --config config/webpack.config.js",
    "build": "webpack --mode=production --config config/webpack.config.js",
    "format": "prettier --write --ignore-unknown \"{config,public,src}/**/*.{html,css,js,ts,json}\"",
    "zip": "npm run build && node -e \"const {execSync}=require('child_process'),pkg=require('./package.json'),ver=pkg.version,out='dist/force-navigator-redux-'+ver+'.zip';require('fs').mkdirSync('dist',{recursive:true});execSync('zip -r ../'+out+' ./',{cwd:'build'});execSync('open dist');\""
  },
  "devDependencies": {
    "copy-webpack-plugin": "^10.2.4",
    "css-loader": "^6.7.3",
    "file-loader": "^6.2.0",
    "mini-css-extract-plugin": "^2.7.2",
    "prettier": "^2.8.1",
    "webpack": "^5.75.0",
    "webpack-cli": "^4.10.0",
    "webpack-merge": "^5.8.0"
  },
  "dependencies": {
    "lisan": "latest",
    "mousetrap": "latest"
  }
}
